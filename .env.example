# Anthropic API キー (必須)
# https://console.anthropic.com/ で取得
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# 本番 URL (必須: カンマ区切りで複数指定可)
# 例: https://hazumi.vercel.app
ALLOWED_ORIGINS=https://your-domain.vercel.app

# Vercel プレビューデプロイを許可する場合は true に設定
# hazumi-*.vercel.app 形式のドメインを許可
ALLOW_VERCEL_PREVIEW=false
